{
  "name": "cleverum",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "chatbot"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:bot",
    "build": "npm-run-all --parallel build:frontend build:bot",
    "dev:frontend": "npm --workspace=frontend run dev",
    "dev:bot": "npm --workspace=chatbot run dev",
    "build:frontend": "npm --workspace=frontend run build",
    "build:bot": "npm --workspace=chatbot run build",
    "start:bot": "npm --workspace=chatbot run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "overrides": {
    "sharp": "0.32.6",
    "protobufjs": ">=7.5.5",
    "jws": ">=3.2.3",
    "follow-redirects": ">=1.15.12",
    "flatted": ">=3.4.2",
    "qs": ">=6.14.2",
    "minimatch": ">=9.0.7",
    "picomatch": ">=3.0.0",
    "path-to-regexp": "0.1.13"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  }
}