# Supabase — service role key (bypasses RLS, required for chatbot writes)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# OpenAI
OPENAI_API_KEY=<openai-api-key>
OPENAI_MODEL=gpt-4o

# WhatsApp Cloud API — global webhook verification token only
# Per-client credentials (phone_number_id, access_token) are stored in the clients table
WHATSAPP_WEBHOOK_SECRET=<your-webhook-verify-token>

# Admin API key — protects /bots/* and /documents/* endpoints
# Must match VITE_ADMIN_API_KEY in the frontend
ADMIN_API_KEY=<random-secret-string>

# Server
PORT=4000
