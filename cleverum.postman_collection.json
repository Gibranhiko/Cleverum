{
  "info": {
    "name": "Cleverum Chatbot API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://cleverum-chatbot-production.up.railway.app",
      "type": "string"
    },
    {
      "key": "admin_api_key",
      "value": "3t3xLYLbT7eMiVZh",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Verify Webhook (GET)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/webhook?hub.mode=subscribe&hub.verify_token=cleverum-webhook-2025&hub.challenge=test123",
              "host": ["{{base_url}}"],
              "path": ["webhook"],
              "query": [
                { "key": "hub.mode", "value": "subscribe" },
                { "key": "hub.verify_token", "value": "cleverum-webhook-2025" },
                { "key": "hub.challenge", "value": "test123" }
              ]
            }
          }
        },
        {
          "name": "Simulate Incoming Message (POST)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/webhook",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"2446516012519294\",\n      \"changes\": [\n        {\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"15556312243\",\n              \"phone_number_id\": \"1085150614682211\"\n            },\n            \"contacts\": [\n              {\n                \"profile\": { \"name\": \"Test User\" },\n                \"wa_id\": \"5215541433545\"\n              }\n            ],\n            \"messages\": [\n              {\n                \"from\": \"5215541433545\",\n                \"id\": \"wamid.test123\",\n                \"timestamp\": \"1777067033\",\n                \"text\": { \"body\": \"Hola\" },\n                \"type\": \"text\"\n              }\n            ]\n          },\n          \"field\": \"messages\"\n        }\n      ]\n    }\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Bots",
      "item": [
        {
          "name": "Get All Bots Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/bots/status",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ]
          }
        },
        {
          "name": "Toggle Bot Active",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/bots/{{client_id}}/toggle",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ]
          }
        },
        {
          "name": "Activate Human Takeover",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bots/{{client_id}}/takeover",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"5215541433545\",\n  \"active\": true\n}"
            }
          }
        },
        {
          "name": "Deactivate Human Takeover",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bots/{{client_id}}/takeover",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"5215541433545\",\n  \"active\": false\n}"
            }
          }
        },
        {
          "name": "Send Message (Human Takeover)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bots/{{client_id}}/send",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"5215541433545\",\n  \"message\": \"Hola, soy un agente. ¿En qué te puedo ayudar?\"\n}"
            }
          }
        },
        {
          "name": "Update WhatsApp Credentials",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/bots/{{client_id}}/credentials",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"wa_phone_number_id\": \"1085150614682211\",\n  \"wa_access_token\": \"YOUR_TOKEN_HERE\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Index Document",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/documents/{{client_id}}/index?documentId=YOUR_DOCUMENT_ID",
              "host": ["{{base_url}}"],
              "path": ["documents", "{{client_id}}", "index"],
              "query": [
                { "key": "documentId", "value": "YOUR_DOCUMENT_ID" }
              ]
            },
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ]
          }
        }
      ]
    }
  ]
}
