# Supabase — anon key (RLS enforces access)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Chatbot backend URL (Railway URL in prod, localhost in dev)
VITE_CHATBOT_URL=http://localhost:4000

# Must match ADMIN_API_KEY in the chatbot backend
VITE_ADMIN_API_KEY=<same-value-as-chatbot-ADMIN_API_KEY>
